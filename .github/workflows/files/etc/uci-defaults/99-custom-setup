#!/bin/sh

# 1. Изменение языка системы на русский
uci set luci.main.lang='ru'
uci commit luci

# 2. Изменение MAC-адреса интерфейса WAN
uci set network.wan.macaddr='04:71:53:7A:5F:3B'
uci commit network

# 3. Создание беспроводной сети Wi-Fi на всех частотах
for radio in $(uci show wireless | grep =wifi-device | cut -d. -f2 | cut -d=-f1); do
    uci set wireless.${radio}.disabled='0'
done

for vif in $(uci show wireless | grep =wifi-iface | cut -d. -f2 | cut -d=-f1); do
    uci set wireless.${vif}.ssid='201'
    uci set wireless.${vif}.encryption='psk2'
    uci set wireless.${vif}.key='Nksvdj131186!!'
done
uci commit wireless

# Перезапуск сетевых служб
/etc/init.d/network restart
/etc/init.d/wireless reload

# Ожидание поднятия интернет-соединения
echo "Waiting for internet connection..."
until ping -c 1 -W 3 1.1.1.1 >/dev/null 2>&1; do
    sleep 5
done

