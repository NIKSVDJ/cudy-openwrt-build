# 5. Установка Podkop
wget -O - https://githubusercontent.com | sh
sleep 15

# Конфигурация Podkop
uci del podkop.config.interfaces
uci add_list podkop.config.interfaces='wg0'
uci add_list podkop.config.interfaces='wg1'
uci add_list podkop.config.interfaces='wg2'
uci set podkop.config.mode='latency'

uci del podkop.config.lists
uci add_list podkop.config.lists='antizapret'
uci set podkop.config.bypass_ru_torrent='1'
uci commit podkop
/etc/init.d/podkop restart

# Включение панели YACD
uci set podkop.config.yacd='1'
uci commit podkop
/etc/init.d/podkop reload

# 6. Настройка adblock-fast
uci set adblock-fast.config.enabled='1'
uci set adblock-fast.config.dns='dnsmasq'
uci set adblock-fast.config.force_dns='1'

uci del adblock-fast.config.url_list
uci add_list adblock-fast.config.url_list='https://adaway.org'
uci add_list adblock-fast.config.url_list='https://firebog.net'
uci add_list adblock-fast.config.url_list='https://firebog.net'
uci commit adblock-fast

# Планировщик обновлений в 00:00
sed -i '/adblock-fast/d' /etc/crontabs/root
echo "0 0 * * * /etc/init.d/adblock-fast reload" >> /etc/crontabs/root

/etc/init.d/cron restart
/etc/init.d/adblock-fast start

exit 0
